{
  "name": "@starter/api",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "api/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "dist/api",
        "format": ["cjs"],
        "bundle": true,
        "main": "api/src/main.ts",
        "tsConfig": "api/tsconfig.app.json",
        "assets": ["api/src/assets"],
        "esbuildConfig": "api/esbuild.config.js"
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "@starter/api:build",
        "buildTargetOptions": {
          "watch": true
        },
        "watch": false
      },
      "configurations": {
        "development": {
          "buildTarget": "@starter/api:build:development"
        },
        "production": {
          "buildTarget": "@starter/api:build:production"
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/test-output/jest/api"],
      "options": {
        "jestConfig": "api/jest.config.js",
        "passWithNoTests": true
      },
      "configurations": {
        "ci": {
          "ci": true,
          "codeCoverage": true
        }
      }
    }
  }
}
