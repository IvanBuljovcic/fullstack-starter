{
  "name": "account-service",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "account-service",
  "projectType": "application",
  "tags": ["type:service", "scope:account"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet build",
        "cwd": "account-service"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet run",
        "cwd": "account-service"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "dotnet test",
        "cwd": "account-service"
      }
    }
  }
}
