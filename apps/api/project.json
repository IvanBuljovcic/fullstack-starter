{
	"name": "@starter/api",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"targets": {
		"build": {
			"executor": "@nx/esbuild:esbuild",
			"outputs": ["{options.outputPath}"],
			"defaultConfiguration": "production",
			"options": {
				"platform": "node",
				"outputPath": "dist/apps/api",
				"format": ["cjs"],
				"bundle": true,
				"main": "apps/api/src/main.ts",
				"tsConfig": "apps/api/tsconfig.app.json",
				"assets": ["apps/api/src/assets"],
				"esbuildConfig": "apps/api/esbuild.config.js"
			},
			"configurations": {
				"development": {},
				"production": {}
			}
		},
		"prune-lockfile": {
			"dependsOn": ["build"],
			"cache": true,
			"executor": "@nx/js:prune-lockfile",
			"outputs": ["{workspaceRoot}/apps/api/dist/package.json", "{workspaceRoot}/apps/api/dist/pnpm-lock.yaml"],
			"options": {
				"buildTarget": "build"
			}
		},
		"copy-workspace-modules": {
			"dependsOn": ["build"],
			"cache": true,
			"outputs": ["{workspaceRoot}/apps/api/dist/workspace_modules"],
			"executor": "@nx/js:copy-workspace-modules",
			"options": {
				"buildTarget": "build"
			}
		},
		"prune": {
			"dependsOn": ["prune-lockfile", "copy-workspace-modules"],
			"executor": "nx:noop"
		},
		"serve": {
			"continuous": true,
			"executor": "@nx/js:node",
			"defaultConfiguration": "development",
			"dependsOn": ["build"],
			"options": {
				"buildTarget": "@starter/api:build",
				"runBuildTargetDependencies": false,
				"watch": false,
				"buildTargetOptions": {
					"watch": true
				}
			},
			"configurations": {
				"development": {
					"buildTarget": "@starter/api:build:development",
					"buildTargetOptions": {
						"args": ["--node-env=development", "--watch"]
					}
				},
				"production": {
					"buildTarget": "@starter/api:build:production"
				}
			}
		},
		"test": {
			"executor": "@nx/jest:jest",
			"outputs": ["{workspaceRoot}/test-output/jest/apps/api"],
			"options": {
				"jestConfig": "apps/api/jest.config.js",
				"passWithNoTests": true
			},
			"configurations": {
				"ci": {
					"ci": true,
					"codeCoverage": true
				},
				"unit": {
					"testPathIgnorePatterns": [".integration.spec.ts"]
				},
				"integration": {
					"testPathPattern": ".integration.spec.ts"
				}
			}
		}
	},
	"sourceRoot": "apps/api/src",
	"projectType": "application",
	"tags": []
}
